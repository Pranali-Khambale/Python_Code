num=[5,10,-3,-1,-10,6]
n=len(num)
result=[0]*n
posI,negI=0,1
for i in range(0,n):
    if num[i]>=0:
        result[posI]=num[i]
        posI+=2
    else:
        result[negI]=num[i]
        negI+=2
print(result)  
